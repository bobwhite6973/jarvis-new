# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one required. Claude is used by default.
ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here

# Default provider: claude | groq | openai
DEFAULT_PROVIDER=claude

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Comma-separated Telegram user IDs allowed to use JARVIS (leave blank = open)
ALLOWED_USER_IDS=123456789,987654321

# ── Bot Control Webhooks ───────────────────────────────────────────────────────
# Format: BOT_CTRL_<BOTNAME>=https://your-render-service.onrender.com/control
BOT_CTRL_ARB=https://your-arb-bot.onrender.com/control
BOT_CTRL_LBANK=https://your-lbank-bot.railway.app/control

# ── Bot Status Endpoints ───────────────────────────────────────────────────────
ARB_BOT_STATUS_URL=https://your-arb-bot.onrender.com/status
